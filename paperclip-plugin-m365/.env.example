# --- Entra (Azure AD) app registration (see docs/SETUP.md) -----------------
M365_CLIENT_ID=
# Tenant: your TSP tenant id (recommended) or "organizations" or "common".
M365_TENANT_ID=organizations
# Must match a redirect URI registered on the app (Mobile/desktop or Web).
M365_REDIRECT_URI=http://localhost:8385/redirect

# Delegated, read-only scopes. offline_access enables silent refresh.
# ReadWrite enables drafting; Calendars.ReadWrite enables calendar holds.
# Add Mail.Send ONLY if you want the explicit, human-confirmed `send` command.
M365_SCOPES=User.Read Mail.ReadWrite Calendars.ReadWrite Files.Read.All Chat.Read offline_access

# Token cache (holds refresh tokens — protect it). Default ~/.paperclip-m365/...
M365_TOKEN_CACHE=

# Only set true if your tenant permits device code flow (many now block it).
M365_USE_DEVICE_CODE=false

# Default false = return metadata only (subjects/senders), no body snippets.
M365_ALLOW_SNIPPETS=false

# Timezone for created calendar holds (IANA, e.g. America/Chicago).
M365_TIMEZONE=America/Chicago
